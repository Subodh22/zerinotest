# Copy this file to ".env" and fill in your real key.
# Get it from the Zernio dashboard: Settings -> API Keys.
# Format: sk_ followed by 64 hex characters.
ZERNIO_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the base URL (defaults to https://zernio.com/api/v1)
# ZERNIO_BASE_URL=https://zernio.com/api/v1

# ── Outlook (Microsoft Graph) ───────────────────────────────────────────────
# Register an app at https://portal.azure.com -> Azure AD -> App registrations.
#  • Redirect URI (Web): http://localhost:3000/api/auth/outlook/callback
#  • API permissions (delegated): offline_access, User.Read, Mail.Read, Mail.Send
#  • Create a client secret under "Certificates & secrets".
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Tenant: "common" works for personal + work accounts; or your directory (tenant) id.
MS_TENANT_ID=common
# Must exactly match the redirect URI registered on the Azure app.
MS_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback

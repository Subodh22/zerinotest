# Copy this file to ".env" and fill in your real values.

# ── Zernio API (shared across all users) ─────────────────────────────────────
# Get it from the Zernio dashboard: Settings -> API Keys.
ZERNIO_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the base URL (defaults to https://zernio.com/api/v1)
# ZERNIO_BASE_URL=https://zernio.com/api/v1

# ── Clerk (user authentication) ─────────────────────────────────────────────
# Get these from https://dashboard.clerk.com -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Turso (database for per-user OAuth tokens) ──────────────────────────────
# Get these from https://turso.tech -> your database -> Connect
# For local dev, leave blank to use a local SQLite file (file:local.db).
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# ── Google / Gmail OAuth (app credentials — shared; user tokens stored in DB) ─
# Create at https://console.cloud.google.com -> Credentials -> OAuth 2.0 Client IDs
# Redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Outlook (Microsoft Graph) ───────────────────────────────────────────────
# Register at https://portal.azure.com -> Azure AD -> App registrations
# Redirect URI: http://localhost:3000/api/auth/outlook/callback
# API permissions (delegated): offline_access, User.Read, Mail.Read, Mail.Send
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
